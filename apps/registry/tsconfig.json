{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "node",
		"baseUrl": ".",
		"paths": {
			"@lib/*": ["./src/lib/*"],
			"@root/*": ["./*"],
			"@src/*": ["./src/*"]
		},
		"types": ["bun-types"],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": false,
		"emitDeclarationOnly": false
	}
}
