<script>
	import { ComponentPreview, ExportItem, APIReference, CodeBlock } from '$lib/components/docs';
	import * as Combobox from '@silk/ui/components/combobox';

	const companies = [
		{ value: "microsoft", label: "Microsoft" },
		{ value: "apple", label: "Apple" },
		{ value: "google", label: "Google" },
		{ value: "facebook", label: "Facebook" },
		{ value: "amazon", label: "Amazon" }
	];
</script>

<ComponentPreview code={`<script>
	import * as Combobox from '@silk/ui/components/combobox';

	const companies = [
		{ value: 'microsoft', label: 'Microsoft' },
		{ value: 'apple', label: 'Apple' },
		{ value: 'google', label: 'Google' }
	];
</script>

<Combobox.Root>
	<Combobox.Trigger variant="outlined" class="w-[220px]">Select company</Combobox.Trigger>
	<Combobox.Content class="w-[220px]">
		<Combobox.Search placeholder="Search companies..." />
		<Combobox.Results>
			{#each companies as company}
				<Combobox.Item value={company.value} label={company.label} callback={() => {}}>
					{company.label}
				</Combobox.Item>
			{/each}
		</Combobox.Results>
	</Combobox.Content>
</Combobox.Root>`}>
	<Combobox.Root>
		<Combobox.Trigger variant="outlined" class="w-[220px]">Select company</Combobox.Trigger>
		<Combobox.Content class="w-[220px]">
			<Combobox.Search placeholder="Search companies..." />
			<Combobox.Results>
				{#each companies as company}
					<Combobox.Item value={company.value} label={company.label} callback={() => {}}>
						{company.label}
					</Combobox.Item>
				{/each}
			</Combobox.Results>
