			{
				property: 'label',
				type: 'string',
				description: 'Optional text label announced alongside the switch.'
			},
			{
				property: 'description',
				type: 'string',
				description: 'Optional supporting copy rendered below the label.'
			},
			{
				property: 'disabled',
				type: 'boolean',
				description: 'Prevents interaction while preserving the current state.',
				defaults: 'false'
			},
			{
				property: 'element',
				type: 'HTMLButtonElement | undefined',
				description: 'A bindable reference to the underlying button element.'
			},
			{
				property: 'class',
				type: 'string',
				description: 'Additional classes applied to the switch track.'
			},
			{
				property: '...rest',
				type: 'HTMLButtonAttributes',
				description: 'Additional button attributes passed to the control.',
