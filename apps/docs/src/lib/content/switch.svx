<h1 class="py-6 h1">API Reference</h1>

<div class="flex flex-col gap-10">
	<APIReference
		title="Switch"
		component="Root"
		description="A smooth, accessible toggle control built on a native button."
		items={[
			{
				property: 'switched',
				type: 'boolean',
				description: 'The current checked state of the switch. Bindable.',
				defaults: 'false'
