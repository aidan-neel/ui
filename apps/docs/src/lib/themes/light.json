{
	"name": "ui-light",
	"type": "light",
	"semanticHighlighting": true,
	"colors": {
		"editor.background": "#f7f8fc",
		"editor.foreground": "#1f2937",
		"editorLineNumber.foreground": "#9aa5b8",
		"editorLineNumber.activeForeground": "#5e6a7d",
		"editor.selectionBackground": "#dbe7ff",
		"editor.inactiveSelectionBackground": "#e8eefc",
		"editor.lineHighlightBackground": "#edf2fb",
		"editorCursor.foreground": "#2f6fed",
		"editorIndentGuide.background": "#e2e8f0",
		"editorWidget.background": "#f7f8fc",
		"editor.findMatchBackground": "#c7d9ff",
		"editor.findMatchHighlightBackground": "#dbe7ff"
	},
	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#8b97aa",
				"fontStyle": "italic"
			}
		},
		{
			"scope": ["keyword", "storage", "keyword.control", "keyword.operator.new"],
			"settings": {
				"foreground": "#295fca"
			}
		},
		{
			"scope": ["entity.name.tag", "support.class.component", "entity.name.type"],
			"settings": {
				"foreground": "#0f766e"
			}
		},
		{
			"scope": ["entity.name.function", "support.function", "meta.function-call"],
			"settings": {
				"foreground": "#1d4ed8"
			}
		},
		{
			"scope": ["variable", "meta.object-literal.key", "support.variable"],
			"settings": {
				"foreground": "#243041"
			}
		},
		{
			"scope": ["string", "string.template", "markup.inline.raw"],
			"settings": {
				"foreground": "#9a3412"
			}
		},
		{
			"scope": ["constant.numeric", "constant.language", "constant.character.escape"],
			"settings": {
				"foreground": "#7c3aed"
			}
		},
		{
			"scope": ["entity.name.type.class", "support.type", "storage.type", "entity.other.attribute-name"],
			"settings": {
				"foreground": "#8f3d8f"
			}
		},
		{
			"scope": ["punctuation", "meta.brace", "meta.delimiter"],
			"settings": {
				"foreground": "#6b7280"
			}
		}
	]
}
