{
	"name": "silk",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.3.11"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"check": "turbo run check",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"lefthook": "^1.13.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"turbo": "^2.5.0"
	}
}
